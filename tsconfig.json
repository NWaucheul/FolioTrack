{
  "compilerOptions": {
    "module": "esnext",
    "target": "ES2020",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationDir": "./typings/",
    "outDir": "./bin/dist",
    "allowJs": true,
    "removeComments": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "bin"]
}
